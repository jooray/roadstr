<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main Action Button - Filled, prominent -->
    <style name="Widget.Roadstr.Button" parent="Widget.Material3.Button">
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="iconTint">@color/onPrimary</item>
        <item name="iconPadding">10dp</item>
        <item name="backgroundTint">@color/primary</item>
    </style>

    <!-- Outlined Button - Secondary actions -->
    <style name="Widget.Roadstr.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="iconPadding">10dp</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="strokeColor">@color/outline</item>
    </style>

    <!-- Text Button - Subtle actions -->
    <style name="Widget.Roadstr.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Event Type Selection Button -->
    <style name="Widget.Roadstr.Button.EventType" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">72dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="android:textColor">@color/onSurfaceVariant</item>
        <item name="iconTint">@color/onSurfaceVariant</item>
    </style>

    <!-- Card Style - Elevated -->
    <style name="Widget.Roadstr.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/surfaceVariant</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- Status Card - Glassmorphism effect -->
    <style name="Widget.Roadstr.Card.Glass">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">6dp</item>
        <item name="cardBackgroundColor">@color/surfaceVariant</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/outline</item>
    </style>

    <!-- Event Item Card -->
    <style name="Widget.Roadstr.Card.Event">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surfaceVariant</item>
    </style>

    <!-- Text Input -->
    <style name="Widget.Roadstr.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxStrokeColor">@color/outline</item>
        <item name="hintTextColor">@color/onSurfaceVariant</item>
    </style>

    <!-- Toolbar Style -->
    <style name="Widget.Roadstr.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/statusBar</item>
        <item name="titleTextColor">@color/onSurface</item>
        <item name="subtitleTextColor">@color/onSurfaceVariant</item>
    </style>

    <!-- Typography using system fonts -->
    <style name="TextAppearance.Roadstr.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Roadstr.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Roadstr.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Roadstr.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Roadstr.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Roadstr.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Roadstr.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Chip Style for filters -->
    <style name="Widget.Roadstr.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">12dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Switch Style -->
    <style name="Widget.Roadstr.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/primary</item>
        <item name="trackTint">@color/primaryContainer</item>
    </style>

</resources>
